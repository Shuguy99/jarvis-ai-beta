# тФАтФАтФА J.A.R.V.I.S. тАФ Environment Variables тФАтФАтФА
# Copy this file to .env and edit as needed.
# All variables are OPTIONAL тАФ defaults work out of the box.

# Ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1
OLLAMA_VISION_MODEL=llava

# Database (SQLite тАФ no configuration needed)
DATABASE_URL=file:./db/jarvis.db