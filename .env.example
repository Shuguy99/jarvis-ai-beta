# ===========================================
# J.A.R.V.I.S. AI — Environment Configuration
# ===========================================
# Скопируйте этот файл как .env и настройте под себя

# ─── Database (SQLite) ─────────────────────
# Путь к файлу базы данных. Относительный от корня проекта.
DATABASE_URL=file:./db/jarvis.db

# ─── Ollama (Local AI) ─────────────────────
# Базовый URL Ollama API (OpenAI-совместимый)
# По умолчанию: http://localhost:11434/v1
OLLAMA_BASE_URL=http://localhost:11434/v1

# Модель для чата. Рекомендуется для 16GB RAM:
#   llama3.1         — 4.7GB, хороший баланс
#   llama3.1:8b      — тоже 4.7GB
#   mistral          — 4.1GB, быстрый
#   phi3             — 2.3GB, лёгкий
#   qwen2.5:7b       — 4.7GB, отлично с русским
OLLAMA_MODEL=llama3.1

# Модель для анализа изображений (нужна поддержка vision)
#   llava            — самый популярный
#   llava:13b        — точнее, но тяжелее
OLLAMA_VISION_MODEL=llava